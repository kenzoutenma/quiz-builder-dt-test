    "express": "^5.2.1",
    "husky": "^9.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "lint-staged": "^17.0.7",
